# Environment Variables for Pacific Duct Backend

# Server Port
PORT=3000

# Email Configuration (Gmail Example)
# For Gmail: Use App Password (not your regular password)
# Enable 2-Step Verification first, then generate App Password
# Go to: https://myaccount.google.com/apppasswords

EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here

# Admin Email (where booking notifications will be sent)
ADMIN_EMAIL=admin@Pacific Duct.com

# SMTP Configuration (if not using Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
